{
  "tasks": [
    {
      "type": "docker-build",
      "label": "docker-build",
      "platform": "python",
      "dockerBuild": {
        "tag": "isn20261:latest",
        "dockerfile": "${workspaceFolder}/rest-api/Dockerfile",
        "context": "${workspaceFolder}/rest-api",
        "pull": true
      }
    },
    {
      "type": "docker-run",
      "label": "docker-run: debug",
      "dependsOn": ["docker-build"],
      "dockerRun": {
        "env": {
          "FLASK_APP": "main.py"
        }
      },
      "python": {
        "args": [
          "run",
          "--no-debugger",
          "--no-reload",
          "--host",
          "0.0.0.0",
          "--port",
          "5000"
        ],
        "module": "flask"
      }
    }
  ]
}
